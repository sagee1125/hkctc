{
  "engines": {
    "node": "18.x"
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/static/(.*)", "destination": "/static/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],

  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@1.0.0"
    }
  }
}
